# String de conexão PostgreSQL (Supabase)
# Obtenha em: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# Servidor
PORT=3000

# CORS — origens permitidas (lista separada por vírgula). Opcional.
# Se ausente, usa o padrão: https://wesleyjuca.github.io,http://localhost:3000
ALLOWED_ORIGINS=https://wesleyjuca.github.io,http://localhost:3000

# E-mail (SMTP) — opcional; habilita envio de notificações por e-mail
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=suasenha
SMTP_SECURE=false
SMTP_FROM=noreply@sema.ac.gov.br

# IA — síntese automática de artigos via Claude (opcional)
# Obtenha em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo Claude usado na síntese (opcional). Padrão: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Autenticação JWT (recomendado em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=substitua-por-string-aleatoria-segura
# Tempo de expiração do token (padrão: 12h)
JWT_EXPIRES=12h
# Admin padrão criado no primeiro boot (se sgua_admin_users estiver vazia)
ADMIN_EMAIL=admin@sema.ac.gov.br
ADMIN_PASSWORD=SemaAC@2026

# Supabase Storage (opcional) — armazena fotos na nuvem em vez do disco local
# Obtenha em: Project Settings → API (Service Role Key)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Log level (debug | info | warn | error — padrão: info)
LOG_LEVEL=info
