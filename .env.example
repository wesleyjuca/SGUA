# String de conexão PostgreSQL (Supabase)
# Obtenha em: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# Servidor
PORT=3000

# CORS — origens permitidas (lista separada por vírgula). Opcional.
# Se ausente, usa o padrão: https://wesleyjuca.github.io,http://localhost:3000
ALLOWED_ORIGINS=https://wesleyjuca.github.io,http://localhost:3000

# E-mail (SMTP) — opcional; habilita envio de notificações por e-mail
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=suasenha
SMTP_SECURE=false
SMTP_FROM=noreply@sema.ac.gov.br

# IA — síntese automática de artigos via Claude (opcional)
# Obtenha em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo Claude usado na síntese (opcional). Padrão: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
